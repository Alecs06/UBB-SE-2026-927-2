<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tests_and_Interviews.Views.InterviewInterviewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests_and_Interviews.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource InterviewPageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="{StaticResource InterviewAccentForegroundBrush}"
                BorderThickness="2"
                CornerRadius="8"
                VerticalAlignment="Center"
                Margin="100">

            <Grid>
                <MediaPlayerElement x:Name="InterviewPlayer"
                                    Source="{x:Bind CreateMediaSource(ViewModel.RecordingUri), Mode=OneWay}"
                                    Stretch="UniformToFill"
                                    AutoPlay="False"
                                    AreTransportControlsEnabled="True">
                    <MediaPlayerElement.TransportControls>
                        <MediaTransportControls IsSkipForwardButtonVisible="False" />
                    </MediaPlayerElement.TransportControls>
                </MediaPlayerElement>

                <Button Content="+ 10s"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="110,0,0,20"
                        Click="Skip10_Click" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowSpacing="8" Margin="0,50,50,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource AppPrimaryBrush}"
                    BorderBrush="{StaticResource InterviewAccentForegroundBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="12"
                    VerticalAlignment="Center">

                <NumberBox x:Name="FormattedNumberBox"
                           Foreground="{StaticResource InterviewAccentForegroundBrush}"
                           Header="Enter Score:"
                           PlaceholderText="1.0"
                           Value="{x:Bind ViewModel.Score, Mode=TwoWay}"/>
            </Border>

            <Button x:Name="SubmitScoreButton"
                    Grid.Row="1"
                    Grid.Column="3"
                    Click="SubmitScore_Click"
                    Style="{StaticResource InterviewActionButtonStyle}"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Submit Score" FontWeight="SemiBold" />
                    <SymbolIcon Symbol="Send" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
