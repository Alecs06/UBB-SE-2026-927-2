<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tests_and_Interviews.Views.RecruiterTestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests_and_Interviews.Views"
    xmlns:vm="using:Tests_and_Interviews.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppPageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AppSurfaceBrush}"
                Padding="32,20"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Click="BackButton_Click"
                        Style="{StaticResource GhostBackButtonStyle}"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Back to Recruiter" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Leaderboard Info"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Select a test to view its detailed leaderboard"
                               Style="{StaticResource PageSubtitleTextStyle}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource AppPanelBackgroundBrush}"
                CornerRadius="12"
                Margin="32,24,32,0"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource AppPrimaryBrush}"
                        CornerRadius="8"
                        Width="36"
                        Height="36"
                        Margin="0,0,14,0">
                    <TextBlock Text="🏆"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Leaderboard Overview"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Text="Choose any test below to open the recruiter leaderboard view."
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyMutedTextStyle}"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="48"
                          Height="48"
                          Foreground="{StaticResource AppPrimaryBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <TextBlock Text="No available tests at the moment."
                       Foreground="{StaticResource AppPrimaryBrush}"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.NoTestsVisible, Mode=OneWay}"/>

            <ScrollViewer Padding="32,20,32,32" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:Name="TestsRepeater"
                               ItemsSource="{x:Bind ViewModel.Tests, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="380" MinColumnSpacing="20" MinRowSpacing="20"/>
                    </ItemsRepeater.Layout>

                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:TestCardViewModel">
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Tag="{x:Bind TestId}"
                                    Click="SeeLeaderboard_Click"
                                    PointerEntered="Card_PointerEntered"
                                    PointerExited="Card_PointerExited">
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        CornerRadius="16"
                                        Padding="24"
                                        BorderThickness="{x:Bind CardBorderThickness, Mode=OneWay}"
                                        BorderBrush="{x:Bind CardBorderBrush, Mode=OneWay}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="{StaticResource AppPrimaryBrush}"
                                                    CornerRadius="20"
                                                    Padding="10,5">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="&lt;/&gt;"
                                                               Foreground="{StaticResource AppSurfaceBrush}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{x:Bind QuestionTypeLabel}"
                                                               Foreground="{StaticResource AppSurfaceBrush}"
                                                               FontSize="11"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>

                                            <Ellipse Grid.Column="2"
                                                     Width="10"
                                                     Height="10"
                                                     Fill="{StaticResource AppSuccessBrush}"
                                                     VerticalAlignment="Center"/>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Text="{x:Bind Title}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AppTitleBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>

                                        <Border Grid.Row="2"
                                                Background="{StaticResource AppPageBackgroundBrush}"
                                                CornerRadius="20"
                                                Padding="12,4"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,12">
                                            <TextBlock Text="{x:Bind Category}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AppSecondaryTextBrush}"/>
                                        </Border>

                                        <Border Grid.Row="3"
                                                Height="1"
                                                Background="{StaticResource AppPageBackgroundBrush}"
                                                Margin="0,0,0,12"/>

                                        <Grid Grid.Row="4" MinHeight="8"/>

                                        <Grid Grid.Row="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="📊"
                                                           FontSize="13"
                                                           Foreground="{StaticResource AppMutedTextBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Leaderboard"
                                                           FontSize="13"
                                                           Foreground="{StaticResource AppMutedTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="See Full Leaderboard →"
                                                       Foreground="{StaticResource AppPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
