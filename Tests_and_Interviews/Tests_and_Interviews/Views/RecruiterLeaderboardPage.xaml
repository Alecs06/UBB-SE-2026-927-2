<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tests_and_Interviews.Views.RecruiterLeaderboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppPageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AppSurfaceBrush}"
                Padding="32,16"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Click="BackToRecruiterTests_Click"
                        Style="{StaticResource GhostBackButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Back to Tests" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="PageTitleText"
                               Text="Recruiter Leaderboard"
                               HorizontalAlignment="Center"
                               Style="{StaticResource PageTitleTextStyle}"/>
                    <TextBlock x:Name="PageSubtitleText"
                               Text="Detailed ranking information"
                               HorizontalAlignment="Center"
                               Style="{StaticResource PageSubtitleTextStyle}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="120,24,120,24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="LeaderboardPanel" Spacing="12"/>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton"
                        Grid.Column="0"
                        Content="Previous"
                        Click="PrevButton_Click"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        IsEnabled="False"/>

                <TextBlock x:Name="PageInfoText"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource AppSecondaryTextBrush}"/>

                <Button x:Name="NextButton"
                        Grid.Column="2"
                        Content="Next"
                        Click="NextButton_Click"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
