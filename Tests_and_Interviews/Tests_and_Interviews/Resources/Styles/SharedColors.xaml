<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Color x:Key="AppPrimaryColor">#8494FF</Color>
	<Color x:Key="AppPageBackgroundColor">#F0EEFF</Color>
	<Color x:Key="AppPanelBackgroundColor">#EEEAFF</Color>
	<Color x:Key="AppBorderColor">#E8E4FF</Color>
	<Color x:Key="AppTitleColor">#1A1A2E</Color>
	<Color x:Key="AppMutedTextColor">#888888</Color>
	<Color x:Key="AppSecondaryTextColor">#555555</Color>
	<Color x:Key="AppSurfaceColor">#FFFFFF</Color>
	<Color x:Key="AppSuccessColor">#22C55E</Color>

	<Color x:Key="InterviewPageBackgroundColor">#C9BEFF</Color>
	<Color x:Key="InterviewAccentForegroundColor">#FFDBFD</Color>
	<Color x:Key="InterviewDangerColor">#FF0000</Color>

	<SolidColorBrush x:Key="AppPrimaryBrush" Color="{StaticResource AppPrimaryColor}" />
	<SolidColorBrush x:Key="AppPageBackgroundBrush" Color="{StaticResource AppPageBackgroundColor}" />
	<SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="{StaticResource AppPanelBackgroundColor}" />
	<SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
	<SolidColorBrush x:Key="AppTitleBrush" Color="{StaticResource AppTitleColor}" />
	<SolidColorBrush x:Key="AppMutedTextBrush" Color="{StaticResource AppMutedTextColor}" />
	<SolidColorBrush x:Key="AppSecondaryTextBrush" Color="{StaticResource AppSecondaryTextColor}" />
	<SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
	<SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource AppSuccessColor}" />

	<SolidColorBrush x:Key="InterviewPageBackgroundBrush" Color="{StaticResource InterviewPageBackgroundColor}" />
	<SolidColorBrush x:Key="InterviewAccentForegroundBrush" Color="{StaticResource InterviewAccentForegroundColor}" />
	<SolidColorBrush x:Key="InterviewDangerBrush" Color="{StaticResource InterviewDangerColor}" />
</ResourceDictionary>