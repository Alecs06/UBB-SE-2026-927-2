<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
		<Setter Property="FontSize" Value="22" />
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="Foreground" Value="{StaticResource AppTitleBrush}" />
	</Style>

	<Style x:Key="PageSubtitleTextStyle" TargetType="TextBlock">
		<Setter Property="FontSize" Value="13" />
		<Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
	</Style>

	<Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
		<Setter Property="FontSize" Value="15" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Foreground" Value="{StaticResource AppTitleBrush}" />
	</Style>

	<Style x:Key="BodyMutedTextStyle" TargetType="TextBlock">
		<Setter Property="FontSize" Value="13" />
		<Setter Property="Foreground" Value="{StaticResource AppSecondaryTextBrush}" />
	</Style>
</ResourceDictionary>